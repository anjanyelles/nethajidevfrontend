# API Configuration
# Set to 'prod' to use production API, 'dev' for localhost
NEXT_PUBLIC_API_ENV=prod

# Production API Base URL
NEXT_PUBLIC_API_BASE_URL=https://nethaji-backend.onrender.com/api/nethaji-service/

# API Timeout (in milliseconds) - Increased for Render cold starts
NEXT_PUBLIC_API_TIMEOUT_MS=180000
